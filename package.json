{
  "name": "web-publish",
  "version": "1.0.0",
  "templateVersion": "1.1.0",
  "description": "HTML Publishing Boilerplate with Bootstrap (Local)",
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "node scripts/dev.js",
    "build": "node scripts/build.js",
    "build:siiru": "BUILD_MODE=siiru node scripts/build.js",
    "preview": "browser-sync start --server dist --no-notify",
    "format:sub-css": "node scripts/format-sub-css.js",
    "format:css": "node scripts/format-sub-css.js",
    "restore:css-sections": "node scripts/restore-css-sections.js",
    "organize:css": "node scripts/restore-css-sections.js && npm run format:sub-css",
    "split:sub-board-css": "node scripts/split-sub-board-css.js && npm run organize:css",
    "start": "npm run dev"
  },
  "devDependencies": {
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "browser-sync": "^3.0.3",
    "css-tree": "^3.1.0",
    "pretendard": "^1.3.9",
    "swiper": "^11.2.10"
  }
}
